rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null
        && request.auth.token.email.matches('.*@safetyculture\\.io$');
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()      { return isAuth() && role() in ['super_admin', 'admin']; }
    function isCSE()        { return isAuth() && role() in ['super_admin', 'admin', 'cse']; }
    function isTeamMember() { return isAuth() && role() in ['super_admin', 'admin', 'cse', 'csm', 'com', 'ae', 'ta']; }
    function isViewer()     { return isAuth(); }

    // ─── /users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isViewer();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAdmin()
                    || (isAuth() && request.auth.uid == uid
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role']));
      allow delete: if isAdmin();
    }

    // ─── /customers ───────────────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read:   if isViewer()
                    || resource.data.shareEnabled == true;
      allow create: if isCSE();
      allow update: if isCSE();
      allow delete: if isAdmin();
    }

    // ─── /customers/activity ──────────────────────────────────────────────────
    // Customer-level notes — append-only for team members
    match /customers/{customerId}/activity/{activityId} {
      allow read:   if isViewer();
      allow create: if isTeamMember();
      allow update: if false; // immutable
      allow delete: if isAdmin();
    }

    // ─── /integrations ────────────────────────────────────────────────────────
    match /integrations/{integrationId} {
      allow read:   if isViewer()
                    || get(/databases/$(database)/documents/customers/$(resource.data.customerId)).data.shareEnabled == true;
      allow create: if isCSE();
      allow update: if isCSE();
      allow delete: if isAdmin();
    }

    // ─── /engagements ─────────────────────────────────────────────────────────
    match /engagements/{engagementId} {
      allow read:   if isViewer()
                    || (resource.data.customerId != null
                        && get(/databases/$(database)/documents/customers/$(resource.data.customerId)).data.shareEnabled == true);
      allow create: if isTeamMember();
      // Customers can update via share link (mark tasks done, add notes).
      // Token in the URL is the access control for unauthenticated writes.
      // TODO: tighten with a Cloud Function token check once on Blaze plan.
      allow update: if isTeamMember() || true;
      allow delete: if isAdmin();

      match /activity/{activityId} {
        allow read:   if isViewer();
        allow create: if isTeamMember();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ─── /teams ───────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read:  if isViewer();
      allow write: if isAdmin();
    }

    // ─── /shareLinks ──────────────────────────────────────────────────────────
    // Public read/update — the 32-char random token in the URL is the access
    // control. Customers look up by token; access count is tracked on each load.
    match /shareLinks/{linkId} {
      allow read:   if isViewer() || true;
      allow create: if isTeamMember();
      allow update: if isTeamMember() || true;
      allow delete: if isAdmin();
    }
  }
}
